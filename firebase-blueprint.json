{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "role": { "type": "string", "enum": ["craftsman", "buyer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "role"]
    },
    "Work": {
      "title": "Work",
      "description": "A piece of work posted by a craftsman",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "craftsmanId": { "type": "string" },
        "craftsmanName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "likesCount": { "type": "number" }
      },
      "required": ["craftsmanId", "title", "imageUrl"]
    },
    "Message": {
      "title": "Message",
      "description": "A message sent between users",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "receiverId", "text"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/works/{workId}": {
      "schema": "Work",
      "description": "Craftsman works"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Direct messages"
    }
  }
}
